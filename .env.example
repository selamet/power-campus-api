# Application
APP_NAME="Power Campus API"
ENVIRONMENT=local
DEBUG=true

# API
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins (the frontend dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
# SQLite for local development; switch to PostgreSQL by changing this URL, e.g.
# postgresql+asyncpg://user:pass@localhost:5432/power_campus
DATABASE_URL=sqlite+aiosqlite:///./power_campus.db

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-only-secret-change-me-0123456789abcdef0123456789
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Seed (initial admin account created by the seed script)
SEED_ADMIN_EMAIL=admin@powerakademi.com
SEED_ADMIN_PASSWORD=admin1234
